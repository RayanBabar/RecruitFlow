# ============================================================
#  Smart Job Portal — Environment Variables
# ============================================================

# --- Modal GPU (Primary LLM backend) ---
# Get this URL after running: modal deploy modal/resume_analyzer.py
# It looks like: https://<workspace>--smart-job-portal-resumeanalyzer-analyze.modal.run
MODAL_ENDPOINT_URL=

# Set to "false" to force local Ollama mode (useful for local dev without Modal)
USE_MODAL=true

# ============================================================
# Copy this file to .env and fill in the values above.
# The .env file is gitignored and should never be committed.
# ============================================================
