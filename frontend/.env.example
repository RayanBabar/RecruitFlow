# ============================================================
#  RecruitFlow — Frontend Environment Variables
# ============================================================

# Database URL (Prisma)
# Replace with your actual PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/smart_job_portal?schema=public"

# NextAuth Configuration
# Generate a secret using `openssl rand -base64 32`
NEXTAUTH_SECRET="your-super-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Initial Admin User (Used for seeding)
ADMIN_EMAIL=admin@recruitflow.com
ADMIN_PASSWORD=adminpassword
ADMIN_NAME="RecruitFlow Admin"

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=youremail@gmail.com
SMTP_PASS=password
MAIL_FROM_NAME=RecruitFlow
MAIL_FROM_ADDRESS=youremail@gmail.com

# ============================================================
# Copy this file to .env and fill in the actual values.
# The .env file is gitignored and should never be committed.
# ============================================================
